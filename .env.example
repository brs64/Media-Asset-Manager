APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=btsplay-mysql
DB_PORT=3306
DB_DATABASE=laravel

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# FFASTRANS CONFIGURATION
FFASTRANS_URL=
FFASTRANS_MOCK_MODE=false
FFASTRANS_PATH_LOCAL="/"
FFASTRANS_PATH_REMOTE=

# FILESYSTEM CONFIGURATION
FILESYSTEM_LOCAL_PATH=

# FTP / NAS PAD CONFIGURATION
FTP_PAD_HOST=btsplay-ftp-pad
FTP_PAD_PORT=21
FTP_PAD_ROOT=/
URI_NAS_PAD_WIN=

# FTP / NAS ARCH CONFIGURATION
FTP_ARCH_HOST=btsplay-ftp-arch
FTP_ARCH_PORT=21
FTP_ARCH_ROOT=/
URI_NAS_ARCH_WIN=

# FTP / NAS MPEG CONFIGURATION
FTP_MPEG_HOST=
FTP_MPEG_PORT=21
FTP_MPEG_ROOT=/

# DATABASE DUMP CONFIGURATION
BACKUP_TIME=04:00
BACKUP_DAY=1
BACKUP_MONTH=*

# ADMIN CONFIGURATION
URI_RACINE_NAS_PAD=
URI_RACINE_NAS_ARCH=
URI_RACINE_STOCKAGE_LOCAL=
URI_RACINE_NAS_DIFF=/

NAS_PAD_IP=
NAS_ARCH_IP=
NAS_DIFF_IP=

URI_FICHIER_GENERES=
URI_DUMP_SAUVEGARDE=
URI_CONSTANTES_SAUVEGARDE=
SUFFIXE_FICHIER_DUMP_SAUVEGARDE=.sql
SUFFIXE_FICHIER_CONSTANTES_SAUVEGARDE=.php

NOM_FICHIER_LOG_GENERAL=historique.log
NOM_FICHIER_LOG_SAUVEGARDE=sauvegardes.log
NB_LIGNES_LOGS=500
AFFICHAGE_LOGS_PLUS_RECENTS_PREMIERS=true

NB_VIDEOS_FFASTRANS=2
WORKFLOW_ID=

NB_MAX_PROCESSUS_TRANSFERT=5
NB_MAX_SOUS_PROCESSUS_TRANSFERT=5

NB_VIDEOS_PAR_SWIPER=10
NB_VIDEOS_HISTORIQUE_TRANSFERT=10

# ---------------------------------
# CREDENTIALS
# ---------------------------------
ADMIN_PASSWORD=
DEFAULT_USER_PASSWORD=

DB_USERNAME=
DB_PASSWORD=
DB_ROOT_PASSWORD=

REDIS_PASSWORD=null

MAIL_USERNAME=null
MAIL_PASSWORD=null

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

FFASTRANS_USER=
FFASTRANS_PASSWORD=

FTP_PAD_USER=
