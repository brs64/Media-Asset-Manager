BACKUP_DAY=1
BACKUP_MONTH=*

# ADMIN CONFIGURATION
URI_RACINE_NAS_PAD=2024-2025/
URI_RACINE_NAS_ARCH=2024-2025/
URI_RACINE_STOCKAGE_LOCAL=/var/www/html/stockage/
URI_RACINE_NAS_DIFF=/

NAS_PAD_IP=
NAS_ARCH_IP=
NAS_DIFF_IP=

